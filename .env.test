# Port number
PORT=3000

NODE_ENV=test

POSTGRESQL_USER=root
POSTGRESQL_PASSWORD=rootpass
POSTGRESQL_DATABASE=app
POSTGRESQL_HOST=localhost:5436

DATABASE_URL=postgresql://${POSTGRESQL_USER}:${POSTGRESQL_PASSWORD}@${POSTGRESQL_HOST}/${POSTGRESQL_DATABASE}?connect_timeout=300

EMONGOLIA_CLIENT_ID=client_id
EMONGOLIA_CLIENT_SECRET=secret
EMONGOLIA_URI=http://localhost
EMONGOLIA_REDIRECT_URI=http://localhost

HES_CLIENT_ID=asd
HES_SALT=asd
HES_PUBLIC_KEY_PATH=asd
HES_API_KEY=key

REDIRECT_URI=http://localhost:3003

APM_SECRET_TOKEN=secret
ELASTIC_URL=http://localhost
