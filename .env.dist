# Port number
PORT=3000

NODE_ENV=dev

# PostgreSQL
POSTGRESQL_USER=root
POSTGRESQL_PASSWORD=rootpass
POSTGRESQL_DATABASE=app
POSTGRESQL_HOST=postgresql:5432

DATABASE_URL=postgresql://${POSTGRESQL_USER}:${POSTGRESQL_PASSWORD}@${POSTGRESQL_HOST}/${POSTGRESQL_DATABASE}?connect_timeout=300

# eMongolia OAuth
EMONGOLIA_CLIENT_ID=
EMONGOLIA_CLIENT_SECRET=
EMONGOLIA_URI=
EMONGOLIA_REDIRECT_URI=

# Redirect base URI (for the gateway's own callback URLs)
REDIRECT_URI=

# HES (RSA notif callback)
HES_CLIENT_ID=
HES_SALT=
HES_PUBLIC_KEY_PATH=
HES_API_KEY=

# Elastic APM (active only in prod)
APM_SECRET_TOKEN=
ELASTIC_URL=
