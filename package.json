{
    "name": "emongolia",
    "version": "v1.0.0",
    "description": "Emongolia RESTAPI",
    "main": "src/index.js",
    "author": "Nyamdorj Kh <nyamdorj.kh@tavanbogd.com>",
    "license": "MIT",
    "engines": {
        "node": ">=12.0.0"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "scripts": {
        "start": "cross-env NODE_ENV=prod node dist/src/index.js",
        "start:migrate": "prisma migrate deploy && prisma generate && cross-env NODE_ENV=prod node dist/src/index.js",
        "dev": "nodemon -L src/index.ts",
        "dev:migrate": "prisma migrate deploy && nodemon -L src/index.ts",
        "build": "tsc -p .",
        "test": "jest -c ./jest.unit.json -i --colors --verbose",
        "test:watch": "jest -c ./jest.unit.json -i --watchAll",
        "prepare": "husky install",
        "coverage": "jest -c ./jest.unit.json -i --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --check **.ts **/*.ts",
        "prettier:fix": "prettier --write **.ts **/*.ts"
    },
    "nodemonConfig": {
        "ignore": [
            "log",
            "responseLog"
        ]
    },
    "keywords": [
        "emongolia"
    ],
    "dependencies": {
        "@prisma/client": "^5.6.0",
        "body-parser": "^1.20.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "cross-env": "^7.0.0",
        "dotenv": "^10.0.0",
        "express": "^4.17.1",
        "helmet": "^4.1.0",
        "http-status": "^1.4.0",
        "joi": "^17.3.0",
        "jsonwebtoken": "^8.5.1",
        "morgan": "^1.9.1",
        "node-fetch": "^2.6.7",
        "reflect-metadata": "^0.1.13",
        "swagger-ui-express": "^4.1.6",
        "tsyringe": "^4.7.0",
        "winston": "^3.2.1",
        "yamljs": "^0.3.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^6.3.1",
        "@types/body-parser": "^1.19.2",
        "@types/compression": "^1.7.2",
        "@types/cors": "^2.8.12",
        "@types/express": "^4.17.13",
        "@types/jest": "^27.5.0",
        "@types/jsonwebtoken": "^8.5.8",
        "@types/morgan": "^1.9.3",
        "@types/node": "^17.0.30",
        "@types/node-fetch": "^2.6.2",
        "@types/supertest": "^2.0.12",
        "@types/swagger-ui-express": "^4.1.3",
        "@types/yamljs": "^0.2.31",
        "@typescript-eslint/eslint-plugin": "^5.27.1",
        "@typescript-eslint/parser": "^5.27.1",
        "elastic-apm-node": "^3.40.0",
        "eslint": "^8.55.0",
        "eslint-config-prettier": "^8.1.0",
        "eslint-plugin-import": "^2.18.2",
        "eslint-plugin-jest": "^24.0.1",
        "eslint-plugin-prettier": "^3.1.1",
        "eslint-plugin-security": "^1.4.0",
        "husky": "^7.0.4",
        "jest": "^27.0.0",
        "jest-mock-extended": "^2.0.5",
        "lint-staged": "^11.0.0",
        "node-mocks-http": "^1.11.0",
        "nodemon": "^2.0.0",
        "prettier": "^2.0.5",
        "prisma": "^5.6.0",
        "supertest": "^6.0.1",
        "ts-jest": "^27.0.0",
        "ts-node": "^10.7.0",
        "typescript": "^4.7.0"
    }
}
